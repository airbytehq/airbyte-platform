    {
      "name": "Direct User paths cover strings active name emails and work email value",
      "resourceType": "User",
      "original": {
        "schemas": ["urn:ietf:params:scim:schemas:core:2.0:User"],
        "id": "user-id",
        "userName": "alice@example.com",
        "active": true,
        "name": { "givenName": "Alice" },
        "emails": [
          { "value": "alice@example.com", "type": "work", "primary": true }
        ]
      },
      "request": {
        "schemas": ["urn:ietf:params:scim:api:messages:2.0:PatchOp"],
        "Operations": [
          {
            "op": "Replace",
            "path": "userName",
            "value": "alicia@example.com"
          },
          { "op": "Replace", "path": "active", "value": false },
          { "op": "Add", "path": "displayName", "value": "Alicia" },
          { "op": "Replace", "path": "name.givenName", "value": "Alicia" },
          { "op": "Replace", "path": "title", "value": "Lead" },
          {
            "op": "Replace",
            "path": "emails",
            "value": [
              {
                "value": "intermediate@example.com",
                "type": "work",
                "primary": true
              }
            ]
          },
          {
            "op": "Replace",
            "path": "emails[type eq \"work\"].value",
            "value": "alicia@example.com"
          }
        ]
      },
      "expected": {
        "schemas": ["urn:ietf:params:scim:schemas:core:2.0:User"],
        "id": "user-id",
        "userName": "alicia@example.com",
        "active": false,
        "name": { "givenName": "Alicia" },
        "emails": [
          { "value": "alicia@example.com", "type": "work", "primary": true }
        ],
        "displayName": "Alicia",
        "title": "Lead"
      }
    },
